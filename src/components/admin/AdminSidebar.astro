---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/admin", label: "Dashboard" },
  { href: "/admin/products", label: "Products" },
  { href: "/admin/users", label: "Users" },
  { href: "/admin/requests", label: "Requests" },
];
---

<aside
  class="w-64 min-h-screen border-r border-zinc-800 bg-zinc-950 px-6 py-8 flex flex-col"
>
  <div class="mb-10">
    <p class="text-xs uppercase tracking-[0.35em] text-zinc-500">Admin Panel</p>
    <h2 class="mt-3 text-2xl font-bold uppercase tracking-[0.28em] text-white">
      Neo.Nautz
    </h2>
  </div>

  <nav
    class="flex flex-col gap-3 text-sm uppercase tracking-[0.22em] text-zinc-400"
  >
    {
      navItems.map((item) => {
        const isActive = currentPath === item.href;

        return (
          <a
            href={item.href}
            class={`rounded-none border px-4 py-3 transition ${
              isActive
                ? "border-white text-white bg-black"
                : "border-transparent hover:border-zinc-700 hover:text-white"
            }`}
          >
            {item.label}
          </a>
        );
      })
    }
  </nav>

  <div
    id="supabase-logout-config"
    data-url={import.meta.env.PUBLIC_SUPABASE_URL}
    data-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    hidden
  >
  </div>

  <div class="mt-auto pt-10">
    <button
      id="logout-button"
      type="button"
      class="w-full border border-zinc-700 px-4 py-3 text-sm uppercase tracking-[0.22em] text-zinc-400 transition hover:border-white hover:text-white"
    >
      Logout
    </button>
  </div>
</aside>

<script>
  import { createBrowserClient } from "@supabase/ssr";

  const configEl = document.getElementById("supabase-logout-config");
  const logoutButton = document.getElementById("logout-button");

  if (
    !(configEl instanceof HTMLElement) ||
    !(logoutButton instanceof HTMLButtonElement)
  ) {
    throw new Error("Logout setup failed");
  }

  const supabaseUrl = configEl.dataset.url;
  const supabaseKey = configEl.dataset.key;

  if (!supabaseUrl || !supabaseKey) {
    throw new Error("Missing Supabase environment variables");
  }

  const supabase = createBrowserClient(supabaseUrl, supabaseKey);

  logoutButton.addEventListener("click", async () => {
    const { error } = await supabase.auth.signOut();

    if (error) {
      console.error("Logout error:", error.message);
      return;
    }

    window.location.href = "/admin/login";
  });
</script>
