---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout>
  <Navbar />

  <section
    class="min-h-screen bg-black text-white px-6 pt-24 md:pt-32 pb-24 flex items-center"
  >
    <div class="max-w-5xl mx-auto w-full">
      <!-- HEADER -->
      <div class="text-center">
        <p class="text-xs md:text-sm uppercase tracking-[0.35em] text-zinc-500">
          About Neo.Nautz
        </p>

        <h1
          class="mt-6 text-4xl md:text-6xl lg:text-7xl font-bold uppercase tracking-[0.14em] leading-tight"
        >
          Built For The Drop
        </h1>

        <p
          class="mt-8 max-w-3xl mx-auto text-sm md:text-base leading-8 text-zinc-400"
        >
          Neo.Nautz exists at the intersection of exclusivity, dark identity and
          controlled releases.
          <br /><br />
          Each drop is not just a product, but a moment — built through image, atmosphere
          and presence.
        </p>
      </div>

      <!-- BLOQUES -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div
          class="border border-white/10 p-8 bg-zinc-950/30 transition duration-300 hover:border-white/30 hover:bg-zinc-900/40"
        >
          <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
            Identity
          </p>

          <h2 class="mt-4 text-2xl font-bold uppercase tracking-[0.12em]">
            Dark Aesthetic
          </h2>

          <p class="mt-4 text-sm leading-7 text-zinc-400">
            A visual direction built on black tones, graffiti influence, rave
            energy and clean silhouettes.
          </p>
        </div>

        <div
          class="border border-white/10 p-8 bg-zinc-950/30 transition duration-300 hover:border-white/30 hover:bg-zinc-900/40"
        >
          <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
            Philosophy
          </p>

          <h2 class="mt-4 text-2xl font-bold uppercase tracking-[0.12em]">
            Limited Drops
          </h2>

          <p class="mt-4 text-sm leading-7 text-zinc-400">
            Every release is treated as a moment. Small runs, focused pieces and
            direct contact with the community.
          </p>
        </div>

        <div
          class="border border-white/10 p-8 bg-zinc-950/30 transition duration-300 hover:border-white/30 hover:bg-zinc-900/40"
        >
          <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Vision</p>

          <h2 class="mt-4 text-2xl font-bold uppercase tracking-[0.12em]">
            Brand Presence
          </h2>

          <p class="mt-4 text-sm leading-7 text-zinc-400">
            Neo.Nautz is not built as mass retail. It is built as a statement
            through image, product and atmosphere.
          </p>
        </div>
      </div>

      <!-- FOOTER TEXT -->
      <div class="mt-20 border-t border-white/10 pt-10 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-600">
          Designed for exclusive release culture
        </p>
      </div>
    </div>
  </section>
</Layout>
