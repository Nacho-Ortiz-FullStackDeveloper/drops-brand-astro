---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <section id="admin-content" class="flex flex-col gap-10">
    <div>
      <p class="text-xs uppercase tracking-[0.35em] text-zinc-500">
        Neo.Nautz Admin
      </p>
      <h1
        class="mt-3 text-3xl font-bold uppercase tracking-[0.22em] text-white md:text-4xl"
      >
        Dashboard
      </h1>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-400">
        Control products, users and requests from one place. This is the private
        management area for the Neo.Nautz project.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
      <article class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Products</p>
        <p class="mt-4 text-4xl font-bold text-white">3</p>
        <p class="mt-2 text-sm text-zinc-400">Current drop items published.</p>
      </article>

      <article class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Users</p>
        <p class="mt-4 text-4xl font-bold text-white">0</p>
        <p class="mt-2 text-sm text-zinc-400">Registered customer accounts.</p>
      </article>

      <article class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Requests</p>
        <p class="mt-4 text-4xl font-bold text-white">0</p>
        <p class="mt-2 text-sm text-zinc-400">
          Open contact and product requests.
        </p>
      </article>

      <article class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">VIP</p>
        <p class="mt-4 text-4xl font-bold text-white">0</p>
        <p class="mt-2 text-sm text-zinc-400">
          Pending VIP access submissions.
        </p>
      </article>
    </div>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-[1.4fr_0.9fr]">
      <section class="border border-zinc-800 bg-zinc-950 p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
              Quick Overview
            </p>
            <h2
              class="mt-2 text-xl font-semibold uppercase tracking-[0.18em] text-white"
            >
              Latest Activity
            </h2>
          </div>
        </div>

        <div class="mt-6 space-y-4">
          <div class="border border-zinc-800 bg-black p-4">
            <p class="text-xs uppercase tracking-[0.24em] text-zinc-500">
              Products
            </p>
            <p class="mt-2 text-sm text-zinc-300">
              TEE V1, HOODIE V1 and CAP V1 are currently available in the
              catalog structure.
            </p>
          </div>

          <div class="border border-zinc-800 bg-black p-4">
            <p class="text-xs uppercase tracking-[0.24em] text-zinc-500">
              Stock Logic
            </p>
            <p class="mt-2 text-sm text-zinc-300">
              Size selection and sold out behaviour are already connected on the
              product pages.
            </p>
          </div>

          <div class="border border-zinc-800 bg-black p-4">
            <p class="text-xs uppercase tracking-[0.24em] text-zinc-500">
              Next Step
            </p>
            <p class="mt-2 text-sm text-zinc-300">
              Connect the dashboard to real authentication and database
              management.
            </p>
          </div>
        </div>
      </section>

      <section class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
          Quick Actions
        </p>
        <h2
          class="mt-2 text-xl font-semibold uppercase tracking-[0.18em] text-white"
        >
          Shortcuts
        </h2>

        <div class="mt-6 flex flex-col gap-3">
          <a
            href="/admin/products"
            class="border border-zinc-700 px-4 py-4 text-sm uppercase tracking-[0.2em] text-zinc-300 transition hover:border-white hover:text-white"
          >
            Manage Products
          </a>

          <a
            href="/admin/users"
            class="border border-zinc-700 px-4 py-4 text-sm uppercase tracking-[0.2em] text-zinc-300 transition hover:border-white hover:text-white"
          >
            View Users
          </a>

          <a
            href="/admin/requests"
            class="border border-zinc-700 px-4 py-4 text-sm uppercase tracking-[0.2em] text-zinc-300 transition hover:border-white hover:text-white"
          >
            Review Requests
          </a>
        </div>
      </section>
    </div>
  </section>

  <script type="module">
    import { supabase } from "../../lib/supabase.js";

    const {
      data: { session },
    } = await supabase.auth.getSession();

    if (!session) {
      window.location.href = "/admin/login";
    }
  </script>
</AdminLayout>
