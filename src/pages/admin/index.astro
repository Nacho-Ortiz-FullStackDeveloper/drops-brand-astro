---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { createServerSupabaseClient } from "../../lib/supabaseServer.js";

const supabase = createServerSupabaseClient(Astro);

// Usuario autenticado
const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect("/admin/login");
}

// Perfil con rol
const { data: profile, error: profileError } = await supabase
  .from("profiles")
  .select("*")
  .eq("id", user.id)
  .single();

if (profileError || !profile || profile.role !== "admin") {
  return Astro.redirect("/");
}

// Número real de productos
const { count: productsCount, error: productsError } = await supabase
  .from("products")
  .select("*", { count: "exact", head: true });

const totalProducts = productsError ? 0 : (productsCount ?? 0);

// Stock total real
const { data: stockRows, error: stockError } = await supabase
  .from("product_sizes")
  .select("stock");

const totalStockUnits = stockError
  ? 0
  : (stockRows ?? []).reduce((sum, item) => sum + (item.stock ?? 0), 0);
---

<AdminLayout>
  <section class="flex flex-col gap-10">
    <div
      class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-zinc-500">
          Neo.Nautz Admin
        </p>
        <h1
          class="mt-3 text-3xl font-bold uppercase tracking-[0.22em] text-white md:text-4xl"
        >
          Dashboard
        </h1>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-400">
          Control products, users and requests from one place. This is the
          private management area for the Neo.Nautz project.
        </p>
      </div>

      <div class="border border-zinc-800 bg-zinc-950 px-5 py-4">
        <p class="text-[10px] uppercase tracking-[0.3em] text-zinc-500">
          Logged in as
        </p>
        <p class="mt-2 text-sm text-white">{user.email}</p>
        <p class="mt-1 text-[10px] uppercase tracking-[0.25em] text-zinc-500">
          Role: {profile.role}
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
      <article class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Products</p>
        <p class="mt-4 text-4xl font-bold text-white">{totalProducts}</p>
        <p class="mt-2 text-sm text-zinc-400">Current products in database.</p>
      </article>

      <article class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
          Stock Units
        </p>
        <p class="mt-4 text-4xl font-bold text-white">{totalStockUnits}</p>
        <p class="mt-2 text-sm text-zinc-400">Total units available by size.</p>
      </article>

      <article class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Requests</p>
        <p class="mt-4 text-4xl font-bold text-white">0</p>
        <p class="mt-2 text-sm text-zinc-400">
          Open contact and product requests.
        </p>
      </article>

      <article class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">VIP</p>
        <p class="mt-4 text-4xl font-bold text-white">0</p>
        <p class="mt-2 text-sm text-zinc-400">
          Pending VIP access submissions.
        </p>
      </article>
    </div>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-[1.4fr_0.9fr]">
      <section class="border border-zinc-800 bg-zinc-950 p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
              Quick Overview
            </p>
            <h2
              class="mt-2 text-xl font-semibold uppercase tracking-[0.18em] text-white"
            >
              Latest Activity
            </h2>
          </div>
        </div>

        <div class="mt-6 space-y-4">
          <div class="border border-zinc-800 bg-black p-4">
            <p class="text-xs uppercase tracking-[0.24em] text-zinc-500">
              Products
            </p>
            <p class="mt-2 text-sm text-zinc-300">
              The dashboard is now reading the total number of products directly
              from Supabase.
            </p>
          </div>

          <div class="border border-zinc-800 bg-black p-4">
            <p class="text-xs uppercase tracking-[0.24em] text-zinc-500">
              Stock
            </p>
            <p class="mt-2 text-sm text-zinc-300">
              Stock is now structured by product size for a real drop-based
              e-commerce workflow.
            </p>
          </div>

          <div class="border border-zinc-800 bg-black p-4">
            <p class="text-xs uppercase tracking-[0.24em] text-zinc-500">
              Next Step
            </p>
            <p class="mt-2 text-sm text-zinc-300">
              Build the products page and manage real stock entries from the
              database.
            </p>
          </div>
        </div>
      </section>

      <section class="border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
          Quick Actions
        </p>
        <h2
          class="mt-2 text-xl font-semibold uppercase tracking-[0.18em] text-white"
        >
          Shortcuts
        </h2>

        <div class="mt-6 flex flex-col gap-3">
          <a
            href="/admin/products"
            class="border border-zinc-700 px-4 py-4 text-sm uppercase tracking-[0.2em] text-zinc-300 transition hover:border-white hover:text-white"
          >
            Manage Products
          </a>

          <a
            href="/admin/users"
            class="border border-zinc-700 px-4 py-4 text-sm uppercase tracking-[0.2em] text-zinc-300 transition hover:border-white hover:text-white"
          >
            View Users
          </a>

          <a
            href="/admin/requests"
            class="border border-zinc-700 px-4 py-4 text-sm uppercase tracking-[0.2em] text-zinc-300 transition hover:border-white hover:text-white"
          >
            Review Requests
          </a>
        </div>
      </section>
    </div>
  </section>
</AdminLayout>
