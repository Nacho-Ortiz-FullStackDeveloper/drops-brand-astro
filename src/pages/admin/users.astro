---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { createServerSupabaseClient } from "../../lib/supabaseServer.js";
import { createAdminSupabaseClient } from "../../lib/supabaseAdmin.js";

type Profile = {
  id: string;
  email: string;
  role: string;
  created_at: string | null;
};

const supabase = createServerSupabaseClient(Astro);
const adminSupabase = createAdminSupabaseClient();

const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect("/admin/login");
}

const { data: currentProfile, error: currentProfileError } = await supabase
  .from("profiles")
  .select("*")
  .eq("id", user.id)
  .single();

if (currentProfileError || !currentProfile || currentProfile.role !== "admin") {
  return Astro.redirect("/");
}

const normalizeText = (value: FormDataEntryValue | null): string =>
  String(value ?? "").trim();

let formError = "";
let formSuccess = "";
let editingUserId = String(Astro.url.searchParams.get("edit") ?? "");

// ACTIONS
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const actionType = normalizeText(formData.get("actionType"));

  if (actionType === "createUser") {
    const email = normalizeText(formData.get("email")).toLowerCase();
    const password = normalizeText(formData.get("password"));
    const role = normalizeText(formData.get("role")) || "user";

    if (!email || !password || !role) {
      formError = "Complete all required user fields correctly.";
    } else if (password.length < 6) {
      formError = "Password must be at least 6 characters.";
    } else {
      const { data: createdUserData, error: createUserError } =
        await adminSupabase.auth.admin.createUser({
          email,
          password,
          email_confirm: true,
        });

      const createdUser = createdUserData?.user;

      if (createUserError || !createdUser) {
        formError = createUserError?.message ?? "Could not create user.";
      } else {
        const { error: insertProfileError } = await adminSupabase
          .from("profiles")
          .upsert({
            id: createdUser.id,
            email,
            role,
          });

        if (insertProfileError) {
          await adminSupabase.auth.admin.deleteUser(createdUser.id);
          formError = insertProfileError.message;
        } else {
          formSuccess = "User created successfully.";
        }
      }
    }
  }

  if (actionType === "updateUser") {
    const userId = normalizeText(formData.get("userId"));
    const email = normalizeText(formData.get("email")).toLowerCase();
    const role = normalizeText(formData.get("role")) || "user";
    const password = normalizeText(formData.get("password"));

    if (!userId || !email || !role) {
      formError = "Complete all required edit fields correctly.";
      editingUserId = userId;
    } else {
      const updatePayload = {
        email,
        ...(password ? { password } : {}),
      };

      const { error: updateAuthError } =
        await adminSupabase.auth.admin.updateUserById(userId, updatePayload);

      if (updateAuthError) {
        formError = updateAuthError.message;
        editingUserId = userId;
      } else {
        const { error: updateProfileError } = await adminSupabase
          .from("profiles")
          .update({
            email,
            role,
          })
          .eq("id", userId);

        if (updateProfileError) {
          formError = updateProfileError.message;
          editingUserId = userId;
        } else {
          formSuccess = "User updated successfully.";
          editingUserId = "";
        }
      }
    }
  }

  if (actionType === "deleteUser") {
    const userId = normalizeText(formData.get("userId"));

    if (!userId) {
      formError = "Missing user id.";
    } else if (userId === user.id) {
      formError = "You cannot delete your own admin account.";
    } else {
      const { error: deleteUserError } =
        await adminSupabase.auth.admin.deleteUser(userId);

      if (deleteUserError) {
        formError = deleteUserError.message;
      } else {
        formSuccess = "User deleted successfully.";
      }
    }
  }
}

// READ DATA
const { data: profiles, error: profilesError } = await adminSupabase
  .from("profiles")
  .select("*")
  .order("created_at", { ascending: false });

const safeProfiles: Profile[] = profilesError
  ? []
  : ((profiles ?? []) as Profile[]);
---

<AdminLayout>
  <section class="flex flex-col gap-8">
    <div
      class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-zinc-500">
          Neo.Nautz Admin
        </p>
        <h1
          class="mt-3 text-3xl font-bold uppercase tracking-[0.22em] text-white md:text-4xl"
        >
          Users
        </h1>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-400">
          Create, manage and remove platform users from one place.
        </p>
      </div>

      <div class="border border-zinc-800 bg-zinc-950 px-5 py-4">
        <p class="text-[10px] uppercase tracking-[0.3em] text-zinc-500">
          Total users
        </p>
        <p class="mt-2 text-2xl font-bold text-white">{safeProfiles.length}</p>
      </div>
    </div>

    {
      (formError || formSuccess) && (
        <div
          class={`border px-5 py-4 text-sm ${
            formError
              ? "border-red-500/40 bg-red-500/10 text-red-300"
              : "border-emerald-500/40 bg-emerald-500/10 text-emerald-300"
          }`}
        >
          {formError || formSuccess}
        </div>
      )
    }

    <section class="border border-zinc-800 bg-zinc-950 p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
        Create User
      </p>
      <h2
        class="mt-2 text-2xl font-semibold uppercase tracking-[0.18em] text-white"
      >
        Add New User
      </h2>

      <form method="POST" class="mt-6 grid grid-cols-1 gap-5 xl:grid-cols-2">
        <input type="hidden" name="actionType" value="createUser" />

        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-2">
            <label
              class="text-[10px] uppercase tracking-[0.28em] text-zinc-500"
            >
              Email
            </label>
            <input
              name="email"
              type="email"
              required
              class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              placeholder="user@neonautz.com"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label
              class="text-[10px] uppercase tracking-[0.28em] text-zinc-500"
            >
              Password
            </label>
            <input
              name="password"
              type="password"
              required
              minlength="6"
              class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              placeholder="Minimum 6 characters"
            />
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-2">
            <label
              class="text-[10px] uppercase tracking-[0.28em] text-zinc-500"
            >
              Role
            </label>
            <select
              name="role"
              required
              class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
            >
              <option value="user">user</option>
              <option value="admin">admin</option>
            </select>
          </div>
        </div>

        <div class="xl:col-span-2">
          <button
            type="submit"
            class="w-full border border-white bg-white px-6 py-3 text-sm uppercase tracking-[0.28em] text-black transition hover:bg-black hover:text-white"
          >
            Add User
          </button>
        </div>
      </form>
    </section>

    <section class="border border-zinc-800 bg-zinc-950 p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Accounts</p>
      <h2
        class="mt-2 text-2xl font-semibold uppercase tracking-[0.18em] text-white"
      >
        Current Users
      </h2>

      {
        safeProfiles.length === 0 ? (
          <div class="mt-6 flex min-h-56 items-center justify-center border border-dashed border-zinc-800 bg-black">
            <p class="text-sm uppercase tracking-[0.25em] text-zinc-500">
              No users found
            </p>
          </div>
        ) : (
          <div class="mt-6 overflow-x-auto border border-zinc-800">
            <table class="min-w-full border-collapse text-sm">
              <thead class="bg-black">
                <tr class="border-b border-zinc-800 text-left">
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Email
                  </th>
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Role
                  </th>
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Created
                  </th>
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Status
                  </th>
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Actions
                  </th>
                </tr>
              </thead>

              <tbody>
                {safeProfiles.map((profile: Profile) => {
                  const isEditing = editingUserId === profile.id;
                  const isCurrentUser = profile.id === user.id;

                  return (
                    <>
                      <tr class="border-b border-zinc-800 bg-zinc-950 align-top">
                        <td class="px-4 py-4 text-white break-all">
                          {profile.email}
                        </td>
                        <td class="px-4 py-4 text-zinc-300">{profile.role}</td>
                        <td class="px-4 py-4 text-zinc-400">
                          {profile.created_at
                            ? new Date(profile.created_at).toLocaleString(
                                "es-ES",
                              )
                            : "No date"}
                        </td>
                        <td class="px-4 py-4">
                          {isCurrentUser ? (
                            <span class="inline-block border border-emerald-500/40 bg-emerald-500/10 px-3 py-2 text-[10px] uppercase tracking-[0.22em] text-emerald-300">
                              Current session
                            </span>
                          ) : (
                            <span class="inline-block border border-zinc-700 px-3 py-2 text-[10px] uppercase tracking-[0.22em] text-zinc-400">
                              Active
                            </span>
                          )}
                        </td>
                        <td class="px-4 py-4">
                          <div class="flex flex-wrap gap-2">
                            <a
                              href={`/admin/users?edit=${profile.id}`}
                              class="border border-zinc-700 px-4 py-2 text-center text-xs uppercase tracking-[0.22em] text-zinc-300 transition hover:border-white hover:text-white"
                            >
                              Edit
                            </a>

                            <form
                              method="POST"
                              onsubmit="return confirm('Are you sure you want to delete this user?');"
                            >
                              <input
                                type="hidden"
                                name="actionType"
                                value="deleteUser"
                              />
                              <input
                                type="hidden"
                                name="userId"
                                value={profile.id}
                              />
                              <button
                                type="submit"
                                disabled={isCurrentUser}
                                class={`border px-4 py-2 text-xs uppercase tracking-[0.22em] transition ${
                                  isCurrentUser
                                    ? "cursor-not-allowed border-zinc-800 text-zinc-600"
                                    : "border-red-500/40 text-red-300 hover:bg-red-500/10"
                                }`}
                              >
                                Delete
                              </button>
                            </form>
                          </div>
                        </td>
                      </tr>

                      {isEditing && (
                        <tr class="border-b border-zinc-800 bg-black">
                          <td colspan="5" class="px-4 py-6">
                            <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                              Edit User
                            </p>

                            <form
                              method="POST"
                              class="mt-4 flex flex-col gap-4"
                            >
                              <input
                                type="hidden"
                                name="actionType"
                                value="updateUser"
                              />
                              <input
                                type="hidden"
                                name="userId"
                                value={profile.id}
                              />

                              <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                                <div class="flex flex-col gap-2">
                                  <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                    Email
                                  </label>
                                  <input
                                    name="email"
                                    type="email"
                                    value={profile.email}
                                    required
                                    class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                  />
                                </div>

                                <div class="flex flex-col gap-2">
                                  <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                    Role
                                  </label>
                                  <select
                                    name="role"
                                    required
                                    class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                  >
                                    <option
                                      value="user"
                                      selected={profile.role === "user"}
                                    >
                                      user
                                    </option>
                                    <option
                                      value="admin"
                                      selected={profile.role === "admin"}
                                    >
                                      admin
                                    </option>
                                  </select>
                                </div>

                                <div class="flex flex-col gap-2">
                                  <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                    New Password
                                  </label>
                                  <input
                                    name="password"
                                    type="password"
                                    minlength="6"
                                    class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                    placeholder="Leave empty to keep current password"
                                  />
                                </div>
                              </div>

                              <div class="flex flex-col gap-3 sm:flex-row">
                                <button
                                  type="submit"
                                  class="border border-white bg-white px-6 py-3 text-sm uppercase tracking-[0.28em] text-black transition hover:bg-black hover:text-white"
                                >
                                  Save Changes
                                </button>

                                <a
                                  href="/admin/users"
                                  class="border border-zinc-700 px-6 py-3 text-center text-sm uppercase tracking-[0.28em] text-zinc-300 transition hover:border-white hover:text-white"
                                >
                                  Cancel
                                </a>
                              </div>
                            </form>
                          </td>
                        </tr>
                      )}
                    </>
                  );
                })}
              </tbody>
            </table>
          </div>
        )
      }
    </section>
  </section>
</AdminLayout>
