---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { createServerSupabaseClient } from "../../lib/supabaseServer.js";
import { createAdminSupabaseClient } from "../../lib/supabaseAdmin.js";

type RequestItem = {
  id: string;
  type: "contact" | "custom_order" | "vip";
  name: string;
  email: string;
  subject: string | null;
  message: string | null;
  phone: string | null;
  status: "new" | "in_progress" | "done" | "cancelled";
  created_at: string | null;
};

const supabase = createServerSupabaseClient(Astro);
const adminSupabase = createAdminSupabaseClient();

const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect("/admin/login");
}

const { data: profile, error: profileError } = await supabase
  .from("profiles")
  .select("*")
  .eq("id", user.id)
  .single();

if (profileError || !profile || profile.role !== "admin") {
  return Astro.redirect("/");
}

const normalizeText = (value: FormDataEntryValue | null): string =>
  String(value ?? "").trim();

let formError = "";
let formSuccess = "";
let editingRequestId = String(Astro.url.searchParams.get("edit") ?? "");

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const actionType = normalizeText(formData.get("actionType"));

  if (actionType === "updateRequestStatus") {
    const requestId = normalizeText(formData.get("requestId"));
    const status = normalizeText(formData.get("status"));

    if (!requestId || !status) {
      formError = "Missing request data.";
      editingRequestId = requestId;
    } else {
      const { error } = await adminSupabase
        .from("requests")
        .update({ status })
        .eq("id", requestId);

      if (error) {
        formError = error.message;
        editingRequestId = requestId;
      } else {
        formSuccess = "Request updated successfully.";
        editingRequestId = "";
      }
    }
  }

  if (actionType === "deleteRequest") {
    const requestId = normalizeText(formData.get("requestId"));

    if (!requestId) {
      formError = "Missing request id.";
    } else {
      const { error } = await adminSupabase
        .from("requests")
        .delete()
        .eq("id", requestId);

      if (error) {
        formError = error.message;
      } else {
        formSuccess = "Request deleted successfully.";
      }
    }
  }
}

const { data: requests, error: requestsError } = await adminSupabase
  .from("requests")
  .select("*")
  .order("created_at", { ascending: false });

const safeRequests: RequestItem[] = requestsError
  ? []
  : ((requests ?? []) as RequestItem[]);

const getTypeLabel = (type: RequestItem["type"]) => {
  if (type === "custom_order") return "Custom Order";
  if (type === "vip") return "VIP";
  return "Contact";
};

const getStatusClasses = (status: RequestItem["status"]) => {
  if (status === "new") {
    return "border-emerald-500/40 bg-emerald-500/10 text-emerald-300";
  }

  if (status === "in_progress") {
    return "border-amber-500/40 bg-amber-500/10 text-amber-300";
  }

  if (status === "done") {
    return "border-blue-500/40 bg-blue-500/10 text-blue-300";
  }

  return "border-red-500/40 bg-red-500/10 text-red-300";
};
---

<AdminLayout>
  <section class="flex flex-col gap-8">
    <div
      class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-zinc-500">
          Neo.Nautz Admin
        </p>
        <h1
          class="mt-3 text-3xl font-bold uppercase tracking-[0.22em] text-white md:text-4xl"
        >
          Requests
        </h1>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-400">
          Review, update and remove incoming requests from the website.
        </p>
      </div>

      <div class="border border-zinc-800 bg-zinc-950 px-5 py-4">
        <p class="text-[10px] uppercase tracking-[0.3em] text-zinc-500">
          Total requests
        </p>
        <p class="mt-2 text-2xl font-bold text-white">{safeRequests.length}</p>
      </div>
    </div>

    {
      (formError || formSuccess) && (
        <div
          class={`border px-5 py-4 text-sm ${
            formError
              ? "border-red-500/40 bg-red-500/10 text-red-300"
              : "border-emerald-500/40 bg-emerald-500/10 text-emerald-300"
          }`}
        >
          {formError || formSuccess}
        </div>
      )
    }

    <section class="border border-zinc-800 bg-zinc-950 p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Requests</p>
      <h2
        class="mt-2 text-2xl font-semibold uppercase tracking-[0.18em] text-white"
      >
        Current Requests
      </h2>

      {
        safeRequests.length === 0 ? (
          <div class="mt-6 flex min-h-56 items-center justify-center border border-dashed border-zinc-800 bg-black">
            <p class="text-sm uppercase tracking-[0.25em] text-zinc-500">
              No requests found
            </p>
          </div>
        ) : (
          <div class="mt-6 overflow-x-auto border border-zinc-800">
            <table class="min-w-full border-collapse text-sm">
              <thead class="bg-black">
                <tr class="border-b border-zinc-800 text-left">
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Type
                  </th>
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Name
                  </th>
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Email
                  </th>
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Status
                  </th>
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Created
                  </th>
                  <th class="px-4 py-4 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                    Actions
                  </th>
                </tr>
              </thead>

              <tbody>
                {safeRequests.map((request: RequestItem) => {
                  const isEditing = editingRequestId === request.id;

                  return (
                    <>
                      <tr class="border-b border-zinc-800 bg-zinc-950 align-top">
                        <td class="px-4 py-4 text-zinc-300">
                          {getTypeLabel(request.type)}
                        </td>
                        <td class="px-4 py-4 text-white">{request.name}</td>
                        <td class="px-4 py-4 text-zinc-300 break-all">
                          {request.email}
                        </td>
                        <td class="px-4 py-4">
                          <span
                            class={`inline-block border px-3 py-2 text-[10px] uppercase tracking-[0.22em] ${getStatusClasses(
                              request.status,
                            )}`}
                          >
                            {request.status.replace("_", " ")}
                          </span>
                        </td>
                        <td class="px-4 py-4 text-zinc-400">
                          {request.created_at
                            ? new Date(request.created_at).toLocaleString(
                                "es-ES",
                              )
                            : "No date"}
                        </td>
                        <td class="px-4 py-4">
                          <div class="flex flex-wrap gap-2">
                            <a
                              href={`/admin/requests?edit=${request.id}`}
                              class="border border-zinc-700 px-4 py-2 text-center text-xs uppercase tracking-[0.22em] text-zinc-300 transition hover:border-white hover:text-white"
                            >
                              View
                            </a>

                            <form
                              method="POST"
                              onsubmit="return confirm('Are you sure you want to delete this request?');"
                            >
                              <input
                                type="hidden"
                                name="actionType"
                                value="deleteRequest"
                              />
                              <input
                                type="hidden"
                                name="requestId"
                                value={request.id}
                              />
                              <button
                                type="submit"
                                class="border border-red-500/40 px-4 py-2 text-xs uppercase tracking-[0.22em] text-red-300 transition hover:bg-red-500/10"
                              >
                                Delete
                              </button>
                            </form>
                          </div>
                        </td>
                      </tr>

                      {isEditing && (
                        <tr class="border-b border-zinc-800 bg-black">
                          <td colspan="6" class="px-4 py-6">
                            <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
                              <div class="space-y-4">
                                <div>
                                  <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                    Type
                                  </p>
                                  <p class="mt-2 text-sm text-white">
                                    {getTypeLabel(request.type)}
                                  </p>
                                </div>

                                <div>
                                  <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                    Name
                                  </p>
                                  <p class="mt-2 text-sm text-white">
                                    {request.name}
                                  </p>
                                </div>

                                <div>
                                  <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                    Email
                                  </p>
                                  <p class="mt-2 break-all text-sm text-white">
                                    {request.email}
                                  </p>
                                </div>

                                <div>
                                  <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                    Phone
                                  </p>
                                  <p class="mt-2 text-sm text-zinc-300">
                                    {request.phone || "No phone"}
                                  </p>
                                </div>

                                <div>
                                  <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                    Subject
                                  </p>
                                  <p class="mt-2 text-sm text-zinc-300">
                                    {request.subject || "No subject"}
                                  </p>
                                </div>
                              </div>

                              <div class="space-y-4">
                                <div>
                                  <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                    Message
                                  </p>
                                  <div class="mt-2 min-h-40 border border-zinc-800 bg-zinc-950 p-4 text-sm leading-7 text-zinc-300 whitespace-pre-wrap">
                                    {request.message || "No message"}
                                  </div>
                                </div>

                                <form method="POST" class="flex flex-col gap-4">
                                  <input
                                    type="hidden"
                                    name="actionType"
                                    value="updateRequestStatus"
                                  />
                                  <input
                                    type="hidden"
                                    name="requestId"
                                    value={request.id}
                                  />

                                  <div class="flex flex-col gap-2">
                                    <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                      Status
                                    </label>
                                    <select
                                      name="status"
                                      required
                                      class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                    >
                                      <option
                                        value="new"
                                        selected={request.status === "new"}
                                      >
                                        new
                                      </option>
                                      <option
                                        value="in_progress"
                                        selected={
                                          request.status === "in_progress"
                                        }
                                      >
                                        in progress
                                      </option>
                                      <option
                                        value="done"
                                        selected={request.status === "done"}
                                      >
                                        done
                                      </option>
                                      <option
                                        value="cancelled"
                                        selected={
                                          request.status === "cancelled"
                                        }
                                      >
                                        cancelled
                                      </option>
                                    </select>
                                  </div>

                                  <div class="flex flex-col gap-3 sm:flex-row">
                                    <button
                                      type="submit"
                                      class="border border-white bg-white px-6 py-3 text-sm uppercase tracking-[0.28em] text-black transition hover:bg-black hover:text-white"
                                    >
                                      Save Changes
                                    </button>

                                    <a
                                      href="/admin/requests"
                                      class="border border-zinc-700 px-6 py-3 text-center text-sm uppercase tracking-[0.28em] text-zinc-300 transition hover:border-white hover:text-white"
                                    >
                                      Close
                                    </a>
                                  </div>
                                </form>
                              </div>
                            </div>
                          </td>
                        </tr>
                      )}
                    </>
                  );
                })}
              </tbody>
            </table>
          </div>
        )
      }
    </section>
  </section>
</AdminLayout>
