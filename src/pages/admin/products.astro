---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { createServerSupabaseClient } from "../../lib/supabaseServer.js";

type Product = {
  id: string;
  name: string;
  price: number;
  description: string;
  image: string;
  created_at: string | null;
};

type ProductSize = {
  id: string;
  product_id: string;
  size: string;
  stock: number;
  created_at?: string | null;
};

type StockMap = Record<string, number>;
type SizesMap = Record<string, ProductSize[]>;

const supabase = createServerSupabaseClient(Astro);

// Auth + role
const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect("/admin/login");
}

const { data: profile, error: profileError } = await supabase
  .from("profiles")
  .select("*")
  .eq("id", user.id)
  .single();

if (profileError || !profile || profile.role !== "admin") {
  return Astro.redirect("/");
}

const parseStock = (value: FormDataEntryValue | null): number => {
  const parsed = Number.parseInt(String(value ?? "").trim(), 10);
  return Number.isNaN(parsed) || parsed < 0 ? 0 : parsed;
};

const normalizeText = (value: FormDataEntryValue | null): string =>
  String(value ?? "").trim();

let formError = "";
let formSuccess = "";
let editingProductId = String(Astro.url.searchParams.get("edit") ?? "");

// ACTIONS
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const actionType = String(formData.get("actionType") ?? "");

  if (actionType === "createProduct") {
    const name = normalizeText(formData.get("name"));
    const priceRaw = normalizeText(formData.get("price"));
    const description = normalizeText(formData.get("description"));
    const image = normalizeText(formData.get("image"));

    const stockS = parseStock(formData.get("stock_s"));
    const stockM = parseStock(formData.get("stock_m"));
    const stockL = parseStock(formData.get("stock_l"));
    const stockXL = parseStock(formData.get("stock_xl"));
    const stockXXL = parseStock(formData.get("stock_xxl"));
    const stockOneSize = parseStock(formData.get("stock_one_size"));

    const price = Number.parseFloat(priceRaw);

    if (!name || !description || !image || Number.isNaN(price)) {
      formError = "Complete all required product fields correctly.";
    } else {
      const { data: insertedProduct, error: insertProductError } =
        await supabase
          .from("products")
          .insert({
            name,
            price,
            description,
            image,
          })
          .select()
          .single();

      if (insertProductError || !insertedProduct) {
        formError = insertProductError?.message ?? "Could not create product.";
      } else {
        const sizeRows: Array<{
          product_id: string;
          size: string;
          stock: number;
        }> = [];

        if (stockOneSize > 0) {
          sizeRows.push({
            product_id: insertedProduct.id,
            size: "One Size",
            stock: stockOneSize,
          });
        } else {
          sizeRows.push(
            { product_id: insertedProduct.id, size: "S", stock: stockS },
            { product_id: insertedProduct.id, size: "M", stock: stockM },
            { product_id: insertedProduct.id, size: "L", stock: stockL },
            { product_id: insertedProduct.id, size: "XL", stock: stockXL },
            { product_id: insertedProduct.id, size: "XXL", stock: stockXXL },
          );
        }

        const { error: insertSizesError } = await supabase
          .from("product_sizes")
          .insert(sizeRows);

        if (insertSizesError) {
          formError = insertSizesError.message;
        } else {
          formSuccess = "Product created successfully.";
        }
      }
    }
  }

  if (actionType === "updateProduct") {
    const productId = normalizeText(formData.get("productId"));
    const name = normalizeText(formData.get("name"));
    const priceRaw = normalizeText(formData.get("price"));
    const description = normalizeText(formData.get("description"));
    const image = normalizeText(formData.get("image"));

    const stockS = parseStock(formData.get("stock_s"));
    const stockM = parseStock(formData.get("stock_m"));
    const stockL = parseStock(formData.get("stock_l"));
    const stockXL = parseStock(formData.get("stock_xl"));
    const stockXXL = parseStock(formData.get("stock_xxl"));
    const stockOneSize = parseStock(formData.get("stock_one_size"));

    const price = Number.parseFloat(priceRaw);

    if (!productId || !name || !description || !image || Number.isNaN(price)) {
      formError = "Complete all required edit fields correctly.";
      editingProductId = productId;
    } else {
      const { error: updateProductError } = await supabase
        .from("products")
        .update({
          name,
          price,
          description,
          image,
        })
        .eq("id", productId);

      if (updateProductError) {
        formError = updateProductError.message;
        editingProductId = productId;
      } else {
        const { error: deleteSizesError } = await supabase
          .from("product_sizes")
          .delete()
          .eq("product_id", productId);

        if (deleteSizesError) {
          formError = deleteSizesError.message;
          editingProductId = productId;
        } else {
          const sizeRows: Array<{
            product_id: string;
            size: string;
            stock: number;
          }> = [];

          if (stockOneSize > 0) {
            sizeRows.push({
              product_id: productId,
              size: "One Size",
              stock: stockOneSize,
            });
          } else {
            sizeRows.push(
              { product_id: productId, size: "S", stock: stockS },
              { product_id: productId, size: "M", stock: stockM },
              { product_id: productId, size: "L", stock: stockL },
              { product_id: productId, size: "XL", stock: stockXL },
              { product_id: productId, size: "XXL", stock: stockXXL },
            );
          }

          const { error: insertUpdatedSizesError } = await supabase
            .from("product_sizes")
            .insert(sizeRows);

          if (insertUpdatedSizesError) {
            formError = insertUpdatedSizesError.message;
            editingProductId = productId;
          } else {
            formSuccess = "Product updated successfully.";
            editingProductId = "";
          }
        }
      }
    }
  }

  if (actionType === "deleteProduct") {
    const productId = normalizeText(formData.get("productId"));

    if (!productId) {
      formError = "Missing product id.";
    } else {
      const { error: deleteError } = await supabase
        .from("products")
        .delete()
        .eq("id", productId);

      if (deleteError) {
        formError = deleteError.message;
      } else {
        formSuccess = "Product deleted successfully.";
      }
    }
  }
}

// READ DATA
const { data: products, error: productsError } = await supabase
  .from("products")
  .select("*")
  .order("created_at", { ascending: false });

const { data: productSizes, error: productSizesError } = await supabase
  .from("product_sizes")
  .select("*");

const safeProducts: Product[] = productsError
  ? []
  : ((products ?? []) as Product[]);
const safeProductSizes: ProductSize[] = productSizesError
  ? []
  : ((productSizes ?? []) as ProductSize[]);

const stockByProductId: StockMap = safeProductSizes.reduce(
  (acc: StockMap, item: ProductSize) => {
    const currentStock = acc[item.product_id] ?? 0;
    acc[item.product_id] = currentStock + (item.stock ?? 0);
    return acc;
  },
  {},
);

const sizesByProductId: SizesMap = safeProductSizes.reduce(
  (acc: SizesMap, item: ProductSize) => {
    if (!acc[item.product_id]) acc[item.product_id] = [];
    acc[item.product_id].push(item);
    return acc;
  },
  {},
);

const getSizeValue = (productId: string, sizeName: string): number => {
  const items = sizesByProductId[productId] ?? [];
  const found = items.find((item: ProductSize) => item.size === sizeName);
  return found?.stock ?? 0;
};
---

<AdminLayout>
  <section class="flex flex-col gap-8">
    <div
      class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-zinc-500">
          Neo.Nautz Admin
        </p>
        <h1
          class="mt-3 text-3xl font-bold uppercase tracking-[0.22em] text-white md:text-4xl"
        >
          Products
        </h1>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-400">
          Manage catalog, stock and image references from one place.
        </p>
      </div>

      <div class="border border-zinc-800 bg-zinc-950 px-5 py-4">
        <p class="text-[10px] uppercase tracking-[0.3em] text-zinc-500">
          Total products
        </p>
        <p class="mt-2 text-2xl font-bold text-white">{safeProducts.length}</p>
      </div>
    </div>

    {
      (formError || formSuccess) && (
        <div
          class={`border px-5 py-4 text-sm ${
            formError
              ? "border-red-500/40 bg-red-500/10 text-red-300"
              : "border-emerald-500/40 bg-emerald-500/10 text-emerald-300"
          }`}
        >
          {formError || formSuccess}
        </div>
      )
    }

    <section class="border border-zinc-800 bg-zinc-950 p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
        Create Product
      </p>
      <h2
        class="mt-2 text-2xl font-semibold uppercase tracking-[0.18em] text-white"
      >
        Add New Item
      </h2>

      <form method="POST" class="mt-6 grid grid-cols-1 gap-5 xl:grid-cols-2">
        <input type="hidden" name="actionType" value="createProduct" />

        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-2">
            <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500"
              >Name</label
            >
            <input
              name="name"
              type="text"
              required
              class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              placeholder="TEE V2"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500"
              >Price</label
            >
            <input
              name="price"
              type="number"
              min="0"
              step="0.01"
              required
              class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              placeholder="60"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500"
              >Image URL</label
            >
            <input
              name="image"
              type="text"
              required
              class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              placeholder="https://... or /images/product.jpg"
            />
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-2">
            <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500"
              >Description</label
            >
            <textarea
              name="description"
              rows="5"
              required
              class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              placeholder="Heavyweight black hoodie with premium fit."
            ></textarea>
          </div>

          <div class="border border-zinc-800 bg-black p-4">
            <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
              Stock by size
            </p>

            <div class="mt-4 grid grid-cols-2 gap-3 md:grid-cols-3">
              <input
                name="stock_s"
                type="number"
                min="0"
                placeholder="S"
                class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              />
              <input
                name="stock_m"
                type="number"
                min="0"
                placeholder="M"
                class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              />
              <input
                name="stock_l"
                type="number"
                min="0"
                placeholder="L"
                class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              />
              <input
                name="stock_xl"
                type="number"
                min="0"
                placeholder="XL"
                class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              />
              <input
                name="stock_xxl"
                type="number"
                min="0"
                placeholder="XXL"
                class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              />
              <input
                name="stock_one_size"
                type="number"
                min="0"
                placeholder="One Size"
                class="border border-zinc-700 bg-zinc-950 px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
              />
            </div>
          </div>
        </div>

        <div class="xl:col-span-2">
          <button
            type="submit"
            class="w-full border border-white bg-white px-6 py-3 text-sm uppercase tracking-[0.28em] text-black transition hover:bg-black hover:text-white"
          >
            Add Product
          </button>
        </div>
      </form>
    </section>

    <section class="border border-zinc-800 bg-zinc-950 p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Catalog</p>
      <h2
        class="mt-2 text-2xl font-semibold uppercase tracking-[0.18em] text-white"
      >
        Current Products
      </h2>

      {
        safeProducts.length === 0 ? (
          <div class="mt-6 flex min-h-56 items-center justify-center border border-dashed border-zinc-800 bg-black">
            <p class="text-sm uppercase tracking-[0.25em] text-zinc-500">
              No products found
            </p>
          </div>
        ) : (
          <div class="mt-6 grid grid-cols-1 gap-5 xl:grid-cols-2">
            {safeProducts.map((product: Product) => {
              const isEditing = editingProductId === product.id;
              const currentSizes = sizesByProductId[product.id] ?? [];
              const hasOneSize = currentSizes.some(
                (item: ProductSize) => item.size === "One Size",
              );

              return (
                <article class="border border-zinc-800 bg-black p-4 h-full">
                  <div class="flex h-full flex-col">
                    <div class="flex items-start gap-4">
                      <div class="h-24 w-24 shrink-0 overflow-hidden border border-zinc-800 bg-zinc-950">
                        {product.image ? (
                          <img
                            src={product.image}
                            alt={product.name}
                            class="h-full w-full object-cover"
                          />
                        ) : (
                          <div class="flex h-full w-full items-center justify-center text-[10px] uppercase tracking-[0.2em] text-zinc-500">
                            No img
                          </div>
                        )}
                      </div>

                      <div class="min-w-0 flex-1">
                        <div class="flex items-start justify-between gap-3">
                          <div>
                            <p class="text-base font-semibold uppercase tracking-[0.12em] text-white">
                              {product.name}
                            </p>
                            <p class="mt-1 text-sm text-zinc-400">
                              €{product.price}
                            </p>
                          </div>

                          <div class="border border-zinc-800 px-3 py-2 text-center">
                            <p class="text-[9px] uppercase tracking-[0.22em] text-zinc-500">
                              Stock
                            </p>
                            <p class="mt-1 text-sm font-bold text-white">
                              {stockByProductId[product.id] ?? 0}
                            </p>
                          </div>
                        </div>

                        <p class="mt-3 line-clamp-2 text-sm leading-6 text-zinc-400">
                          {product.description}
                        </p>
                      </div>
                    </div>

                    <div class="mt-4 grid grid-cols-1 gap-3">
                      <div>
                        <p class="text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                          Sizes
                        </p>
                        <p class="mt-1 text-xs leading-5 text-zinc-400">
                          {currentSizes
                            .map(
                              (item: ProductSize) =>
                                `${item.size}: ${item.stock}`,
                            )
                            .join(" · ") || "No stock data"}
                        </p>
                      </div>

                      <div>
                        <p class="text-[10px] uppercase tracking-[0.22em] text-zinc-500">
                          Image URL
                        </p>
                        <p class="mt-1 line-clamp-1 break-all text-xs text-zinc-400">
                          {product.image}
                        </p>
                      </div>
                    </div>

                    <div class="mt-4 grid grid-cols-2 gap-3">
                      <a
                        href={`/admin/products?edit=${product.id}`}
                        class="border border-zinc-700 px-4 py-2 text-center text-xs uppercase tracking-[0.22em] text-zinc-300 transition hover:border-white hover:text-white"
                      >
                        Edit
                      </a>

                      <form method="POST">
                        <input
                          type="hidden"
                          name="actionType"
                          value="deleteProduct"
                        />
                        <input
                          type="hidden"
                          name="productId"
                          value={product.id}
                        />
                        <button
                          type="submit"
                          class="w-full border border-red-500/40 px-4 py-2 text-xs uppercase tracking-[0.22em] text-red-300 transition hover:bg-red-500/10"
                        >
                          Delete
                        </button>
                      </form>
                    </div>

                    {isEditing && (
                      <div class="mt-4 border-t border-zinc-800 pt-4">
                        <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                          Edit Product
                        </p>

                        <form method="POST" class="mt-4 flex flex-col gap-4">
                          <input
                            type="hidden"
                            name="actionType"
                            value="updateProduct"
                          />
                          <input
                            type="hidden"
                            name="productId"
                            value={product.id}
                          />

                          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                            <div class="flex flex-col gap-2">
                              <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                Name
                              </label>
                              <input
                                name="name"
                                type="text"
                                value={product.name}
                                required
                                class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                              />
                            </div>

                            <div class="flex flex-col gap-2">
                              <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                                Price
                              </label>
                              <input
                                name="price"
                                type="number"
                                min="0"
                                step="0.01"
                                value={product.price}
                                required
                                class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                              />
                            </div>
                          </div>

                          <div class="flex flex-col gap-2">
                            <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                              Image URL
                            </label>
                            <input
                              name="image"
                              type="text"
                              value={product.image}
                              required
                              class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                            />
                          </div>

                          <div class="flex flex-col gap-2">
                            <label class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                              Description
                            </label>
                            <textarea
                              name="description"
                              rows="4"
                              required
                              class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                            >
                              {product.description}
                            </textarea>
                          </div>

                          <div class="border border-zinc-800 bg-zinc-950 p-4">
                            <p class="text-[10px] uppercase tracking-[0.28em] text-zinc-500">
                              Stock by size
                            </p>

                            {hasOneSize ? (
                              <div class="mt-4 grid grid-cols-1 gap-3">
                                <input
                                  name="stock_one_size"
                                  type="number"
                                  min="0"
                                  value={getSizeValue(product.id, "One Size")}
                                  placeholder="One Size"
                                  class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                />
                                <input type="hidden" name="stock_s" value="0" />
                                <input type="hidden" name="stock_m" value="0" />
                                <input type="hidden" name="stock_l" value="0" />
                                <input
                                  type="hidden"
                                  name="stock_xl"
                                  value="0"
                                />
                                <input
                                  type="hidden"
                                  name="stock_xxl"
                                  value="0"
                                />
                              </div>
                            ) : (
                              <div class="mt-4 grid grid-cols-2 gap-3 md:grid-cols-3">
                                <input
                                  name="stock_s"
                                  type="number"
                                  min="0"
                                  value={getSizeValue(product.id, "S")}
                                  placeholder="S"
                                  class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                />
                                <input
                                  name="stock_m"
                                  type="number"
                                  min="0"
                                  value={getSizeValue(product.id, "M")}
                                  placeholder="M"
                                  class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                />
                                <input
                                  name="stock_l"
                                  type="number"
                                  min="0"
                                  value={getSizeValue(product.id, "L")}
                                  placeholder="L"
                                  class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                />
                                <input
                                  name="stock_xl"
                                  type="number"
                                  min="0"
                                  value={getSizeValue(product.id, "XL")}
                                  placeholder="XL"
                                  class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                />
                                <input
                                  name="stock_xxl"
                                  type="number"
                                  min="0"
                                  value={getSizeValue(product.id, "XXL")}
                                  placeholder="XXL"
                                  class="border border-zinc-700 bg-black px-4 py-3 text-sm text-white focus:border-white focus:outline-none"
                                />
                                <input
                                  type="hidden"
                                  name="stock_one_size"
                                  value="0"
                                />
                              </div>
                            )}
                          </div>

                          <div class="flex flex-col gap-3 sm:flex-row">
                            <button
                              type="submit"
                              class="border border-white bg-white px-6 py-3 text-sm uppercase tracking-[0.28em] text-black transition hover:bg-black hover:text-white"
                            >
                              Save Changes
                            </button>

                            <a
                              href="/admin/products"
                              class="border border-zinc-700 px-6 py-3 text-center text-sm uppercase tracking-[0.28em] text-zinc-300 transition hover:border-white hover:text-white"
                            >
                              Cancel
                            </a>
                          </div>
                        </form>
                      </div>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        )
      }
    </section>
  </section>
</AdminLayout>
