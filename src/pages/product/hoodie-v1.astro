---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { Image } from "astro:assets";

import hoodie01 from "../../assets/images/hoodie-01.png";
import hoodie02 from "../../assets/images/hoodie-02.png";
import hoodie03 from "../../assets/images/hoodie-03.png";

const product = {
  name: "HOODIE V1",
  price: "€120",
  description:
    "Heavyweight black hoodie with bold Neo.Nautz front and back graphics. Built for a dark urban silhouette with a strong drop identity and premium streetwear feel.",
  soldOut: false,
  images: [
    { src: hoodie01, alt: "Hoodie NEO.NAUTZ image 1" },
    { src: hoodie02, alt: "Hoodie NEO.NAUTZ image 2" },
    { src: hoodie03, alt: "Hoodie NEO.NAUTZ image 3" },
  ],
  sizes: [
    { name: "S", stock: 1 },
    { name: "M", stock: 0 },
    { name: "L", stock: 3 },
    { name: "XL", stock: 2 },
    { name: "XXL", stock: 0 },
  ],
};
---

<Layout>
  <Navbar />

  <section class="min-h-screen bg-black text-white px-6 py-32">
    <div
      class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
    >
      <!-- GALERÍA -->
      <div class="w-full flex flex-col items-center">
        <div
          class="w-full max-w-md overflow-hidden border border-gray-800 bg-black"
        >
          <div class="relative overflow-hidden">
            <div
              id="product-slider"
              class="flex transition-transform duration-500 ease-in-out"
              style={`width: ${product.images.length * 100}%`}
            >
              {
                product.images.map((image) => (
                  <div
                    class="shrink-0"
                    style={`width: ${100 / product.images.length}%`}
                  >
                    <Image
                      src={image.src}
                      alt={image.alt}
                      width={800}
                      height={1000}
                      class="w-full h-130 object-cover object-center"
                    />
                  </div>
                ))
              }
            </div>

            {
              product.images.length > 1 && (
                <>
                  <button
                    id="product-prev"
                    class="absolute left-3 top-1/2 -translate-y-1/2 border border-white/20 bg-black/80 px-3 py-2 text-[10px] uppercase tracking-[0.3em] text-white transition hover:border-white hover:bg-white hover:text-black"
                    aria-label="Previous image"
                  >
                    Prev
                  </button>

                  <button
                    id="product-next"
                    class="absolute right-3 top-1/2 -translate-y-1/2 border border-white/20 bg-black/80 px-3 py-2 text-[10px] uppercase tracking-[0.3em] text-white transition hover:border-white hover:bg-white hover:text-black"
                    aria-label="Next image"
                  >
                    Next
                  </button>
                </>
              )
            }
          </div>
        </div>

        {
          product.images.length > 1 && (
            <div class="mt-6 flex justify-center gap-3">
              {product.images.map((_, index) => (
                <button
                  class={`product-dot h-2 w-2 rounded-full transition ${
                    index === 0 ? "bg-white" : "bg-white/20"
                  }`}
                  data-index={index}
                  aria-label={`Go to image ${index + 1}`}
                />
              ))}
            </div>
          )
        }
      </div>

      <!-- INFO -->
      <div class="flex flex-col gap-6">
        <p class="text-xs tracking-[0.3em] text-gray-500 uppercase">
          NEO.NAUTZ / DROP 01
        </p>

        <h1 class="text-4xl md:text-6xl font-bold tracking-widest uppercase">
          {product.name}
        </h1>

        <div class="flex items-center gap-4 flex-wrap">
          <p class="text-2xl text-gray-300">
            {product.price}
          </p>

          {
            product.soldOut && (
              <span class="border border-white/20 px-3 py-1 text-xs uppercase tracking-[0.28em] text-zinc-400">
                Sold Out
              </span>
            )
          }
        </div>

        <p class="text-sm leading-7 text-gray-400 max-w-xl">
          {product.description}
        </p>

        <!-- SIZES -->
        <div class="flex flex-col gap-4 pt-2">
          <div class="flex justify-between items-center gap-4">
            <p class="text-xs uppercase tracking-[0.28em] text-gray-500">
              Select Size
            </p>
            <p
              id="selected-size-label"
              class="text-xs uppercase tracking-[0.2em] text-gray-400"
            >
              No size selected
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            {
              product.sizes.map((size) => {
                const isSoldOut = size.stock === 0;

                return (
                  <button
                    type="button"
                    class={`size-option min-w-17 border px-4 py-3 text-xs uppercase tracking-[0.25em] transition ${
                      isSoldOut
                        ? "border-gray-800 text-gray-600 opacity-40 cursor-not-allowed"
                        : "border-gray-700 text-white hover:border-white"
                    }`}
                    data-size={size.name}
                    data-stock={size.stock}
                    disabled={isSoldOut}
                  >
                    {size.name}
                  </button>
                );
              })
            }
          </div>

          <p
            id="size-stock-message"
            class="text-xs uppercase tracking-[0.18em] text-gray-500"
          >
            Select a size to check availability
          </p>
        </div>

        <!-- CTA -->
        <div class="flex gap-3 pt-2 flex-wrap">
          <button
            id="product-cta"
            disabled
            class="border border-gray-700 px-6 py-3 text-gray-500 uppercase cursor-not-allowed transition"
          >
            Select Size
          </button>

          <a
            href="/#drop"
            class="border border-gray-700 px-6 py-3 text-sm tracking-widest text-gray-300 uppercase hover:border-white hover:text-white transition"
          >
            Back
          </a>
        </div>
      </div>
    </div>
  </section>

  <script
    is:inline
    define:vars={{
      imageCount: product.images.length,
      productName: product.name,
    }}
  >
    const slider = document.getElementById("product-slider");
    const prevBtn = document.getElementById("product-prev");
    const nextBtn = document.getElementById("product-next");
    const dots = Array.from(document.querySelectorAll(".product-dot"));

    if (slider && imageCount > 1) {
      let current = 0;

      const updateSlider = () => {
        slider.style.transform = `translateX(-${current * (100 / imageCount)}%)`;

        dots.forEach((dot, index) => {
          dot.classList.toggle("bg-white", index === current);
          dot.classList.toggle("bg-white/20", index !== current);
        });
      };

      prevBtn?.addEventListener("click", () => {
        current = current === 0 ? imageCount - 1 : current - 1;
        updateSlider();
      });

      nextBtn?.addEventListener("click", () => {
        current = current === imageCount - 1 ? 0 : current + 1;
        updateSlider();
      });

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
          current = index;
          updateSlider();
        });
      });

      updateSlider();
    }

    const sizeButtons = Array.from(document.querySelectorAll(".size-option"));
    const selectedSizeLabel = document.getElementById("selected-size-label");
    const sizeStockMessage = document.getElementById("size-stock-message");
    const productCta = document.getElementById("product-cta");

    let selectedSize = null;

    const resetSizeButtons = () => {
      sizeButtons.forEach((btn) => {
        if (!btn.disabled) {
          btn.classList.remove("border-white", "bg-white", "text-black");
          btn.classList.add("border-gray-700", "text-white");
        }
      });
    };

    sizeButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const stock = Number(btn.dataset.stock || 0);
        const size = btn.dataset.size || "";

        selectedSize = size;

        resetSizeButtons();

        btn.classList.remove("border-gray-700", "text-white");
        btn.classList.add("border-white", "bg-white", "text-black");

        if (selectedSizeLabel) {
          selectedSizeLabel.textContent = `Selected: ${size}`;
        }

        if (sizeStockMessage) {
          if (stock <= 2) {
            sizeStockMessage.textContent = `Only ${stock} left in ${size}`;
          } else {
            sizeStockMessage.textContent = `${size} is available`;
          }
        }

        if (productCta) {
          productCta.textContent = `Request ${size}`;
          productCta.removeAttribute("disabled");
          productCta.classList.remove(
            "border-gray-700",
            "text-gray-500",
            "cursor-not-allowed",
          );
          productCta.classList.add(
            "border-white",
            "text-white",
            "hover:bg-white",
            "hover:text-black",
            "cursor-pointer",
          );
        }
      });
    });

    productCta?.addEventListener("click", () => {
      if (!selectedSize) return;

      const text = `Hello, I want ${productName} size ${selectedSize}`;
      window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, "_blank");
    });
  </script>
</Layout>
