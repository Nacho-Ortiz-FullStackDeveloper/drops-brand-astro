---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout>
  <Navbar />

  <section class="min-h-screen bg-black text-white px-6 pt-24 pb-24">
    <div class="max-w-3xl mx-auto">
      
      <h1 class="text-3xl md:text-5xl font-bold uppercase tracking-[0.14em]">
        Privacy Policy
      </h1>

      <p class="mt-8 text-sm text-zinc-400 leading-7">
        Neo.Nautz does not collect personal data through this website.
      </p>

      <p class="mt-6 text-sm text-zinc-400 leading-7">
        Any contact made via email or WhatsApp is voluntary and used only to respond to inquiries and manage product requests.
      </p>

      <p class="mt-6 text-sm text-zinc-400 leading-7">
        We do not share, sell or store personal data beyond what is necessary for communication.
      </p>

      <p class="mt-6 text-sm text-zinc-400 leading-7">
        For any privacy-related questions, contact:
        <br />
        <span class="text-white">vip@neonautz.com</span>
      </p>

    </div>
  </section>
</Layout>