---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout>
  <Navbar />

  <!-- HERO -->
  <section class="h-screen bg-black flex flex-col items-center justify-center text-white gap-6">
    <h1 class="text-6xl md:text-8xl font-bold tracking-widest hover:tracking-[0.2em] transition-all duration-500">
      NEO.NAUTZ
    </h1>

    <p class="text-sm tracking-[0.3em] text-gray-400">
      EXCLUSIVE DROPS
    </p>

    <a href="#drop" class="border border-white px-6 py-3 text-sm tracking-widest transition-all duration-300 hover:bg-white hover:text-black hover:scale-105">
      SHOP
    </a>

    <p id="countdown" class="text-xs text-gray-500 mt-6 tracking-widest"></p>

    <script>
      const countdown = document.getElementById("countdown");

      const dropDate = new Date();
      dropDate.setHours(dropDate.getHours() + 48);

      function updateCountdown() {
        const now = new Date();
        const diff = dropDate - now;

        if (diff <= 0) {
          if (countdown) countdown.innerText = "DROP LIVE";
          return;
        }

        const hours = Math.floor(diff / (1000 * 60 * 60));
        const minutes = Math.floor((diff / (1000 * 60)) % 60);
        const seconds = Math.floor((diff / 1000) % 60);

        if (countdown) {
          countdown.innerText = `NEXT DROP IN ${hours}H ${minutes}M ${seconds}S`;
        }
      }

      updateCountdown();
      setInterval(updateCountdown, 1000);
    </script>
  </section>

  <!-- DROP -->
  <section id="drop" class="bg-black text-white py-20 px-6">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-16 tracking-widest">
      LATEST DROP
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-6xl mx-auto">

      <!-- PRODUCTO 1 -->
      <article class="group">
        <div class="overflow-hidden border border-gray-800 hover:border-white transition-all duration-300">
          <div class="h-80 bg-zinc-900 flex items-center justify-center text-zinc-600 tracking-[0.3em] group-hover:scale-105 transition-transform duration-500">
            HOODIE
          </div>
        </div>
        <div class="mt-4 flex items-center justify-between">
          <h3 class="text-sm md:text-base tracking-[0.25em]">HOODIE V1</h3>
          <p class="text-sm text-gray-400">€120</p>
        </div>
      </article>

      <!-- PRODUCTO 2 -->
      <article class="group">
        <div class="overflow-hidden border border-gray-800 hover:border-white transition-all duration-300">
          <div class="h-80 bg-zinc-900 flex items-center justify-center text-zinc-600 tracking-[0.3em] group-hover:scale-105 transition-transform duration-500">
            TEE
          </div>
        </div>
        <div class="mt-4 flex items-center justify-between">
          <h3 class="text-sm md:text-base tracking-[0.25em]">TEE V1</h3>
          <p class="text-sm text-gray-400">€60</p>
        </div>
      </article>

      <!-- PRODUCTO 3 -->
      <article class="group">
        <div class="overflow-hidden border border-gray-800 hover:border-white transition-all duration-300">
          <div class="h-80 bg-zinc-900 flex items-center justify-center text-zinc-600 tracking-[0.3em] group-hover:scale-105 transition-transform duration-500">
            CAP
          </div>
        </div>
        <div class="mt-4 flex items-center justify-between">
          <h3 class="text-sm md:text-base tracking-[0.25em]">CAP V1</h3>
          <p class="text-sm text-gray-400">€40</p>
        </div>
      </article>

    </div>
  </section>

</Layout>