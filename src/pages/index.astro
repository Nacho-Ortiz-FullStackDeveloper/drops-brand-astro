---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import ProductCard from "../components/ProductCard.astro";
import BehindTheDrop from "../components/BehindTheDrop.astro";

import hoodie from "../assets/images/hoodie.png";
import tee from "../assets/images/tee.png";
import cap from "../assets/images/cap.png";

/* CAMPAIGN IMAGES */
import campaign01 from "../assets/campaign/drop-01.png";
import campaign02 from "../assets/campaign/drop-02.png";
import campaign03 from "../assets/campaign/drop-03.png";
import campaign04 from "../assets/campaign/drop-04.png";
import campaign05 from "../assets/campaign/drop-05.png";
import campaign06 from "../assets/campaign/drop-06.png";
import campaign07 from "../assets/campaign/drop-07.png";
import campaign08 from "../assets/campaign/drop-08.png";
import campaign09 from "../assets/campaign/drop-09.png";
---

<Layout>
  <Navbar />

  <!-- HERO -->
  <section
    class="h-screen bg-black flex flex-col items-center justify-center text-white px-6"
  >
    <div class="flex flex-col items-center text-center max-w-4xl mx-auto">
      <h1
        class="text-6xl md:text-8xl lg:text-9xl font-bold tracking-[0.12em] uppercase leading-none hover:tracking-[0.18em] transition-all duration-500"
      >
        NEO.NAUTZ
      </h1>

      <p
        class="mt-8 text-base md:text-xl uppercase tracking-[0.45em] text-zinc-300"
      >
        Exclusive Drops
      </p>

      <a
        href="#drop"
        class="mt-10 inline-flex items-center justify-center border border-white px-8 py-4 text-sm md:text-base uppercase tracking-[0.28em] transition-all duration-300 hover:bg-white hover:text-black hover:scale-105"
      >
        Shop
      </a>

      <div class="mt-12 flex flex-col items-center gap-4">
        <p
          id="countdown"
          class="text-base md:text-xl font-medium uppercase tracking-[0.22em] text-white"
        >
        </p>

        <p
          id="local-drop-time"
          class="text-xs md:text-sm uppercase tracking-[0.28em] text-zinc-500"
        >
        </p>

        <a
          href="/vip"
          class="mt-4 inline-flex items-center justify-center border border-white px-8 py-4 text-sm md:text-base uppercase tracking-[0.28em] transition-all duration-300 hover:bg-white hover:text-black hover:scale-105"
        >
          Vip
        </a>
      </div>
    </div>

    <script is:inline>
      const countdown = document.getElementById("countdown");
      const localDropTime = document.getElementById("local-drop-time");

      const DROP_DATE = "2026-07-21T20:00:00+02:00";
      const dropDate = new Date(DROP_DATE);

      if (localDropTime) {
        const formattedLocalTime = new Intl.DateTimeFormat(undefined, {
          day: "2-digit",
          month: "short",
          year: "numeric",
          hour: "2-digit",
          minute: "2-digit",
        }).format(dropDate);

        localDropTime.textContent = `Your local drop time: ${formattedLocalTime}`;
      }

      function updateCountdown() {
        const now = new Date();
        const diff = dropDate.getTime() - now.getTime();

        if (diff <= 0) {
          if (countdown) countdown.textContent = "Drop Live";
          return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
        const minutes = Math.floor((diff / (1000 * 60)) % 60);
        const seconds = Math.floor((diff / 1000) % 60);

        if (countdown) {
          countdown.textContent = `Next drop in ${days}d ${hours}h ${minutes}m ${seconds}s`;
        }
      }

      updateCountdown();
      setInterval(updateCountdown, 1000);
    </script>
  </section>

  <!-- BEHIND THE DROP -->
  <BehindTheDrop
    title="BEHIND THE DROP"
    subtitle="Campaign visuals from the current release."
    images={[
      { image: campaign01, alt: "Campaign shot 1" },
      { image: campaign02, alt: "Campaign shot 2" },
      { image: campaign03, alt: "Campaign shot 3" },
      { image: campaign04, alt: "Campaign shot 4" },
      { image: campaign05, alt: "Campaign shot 5" },
      { image: campaign06, alt: "Campaign shot 6" },
      { image: campaign07, alt: "Campaign shot 7" },
      { image: campaign08, alt: "Campaign shot 8" },
      { image: campaign09, alt: "Campaign shot 9" },
    ]}
  />

  <!-- DROP -->
  <section id="drop" class="bg-black text-white py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-5xl font-bold text-center uppercase tracking-[0.18em] mb-16"
      >
        Latest Drop
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <ProductCard
          image={hoodie}
          alt="Hoodie NEO.NAUTZ"
          name="HOODIE V1"
          price="€120"
          href="/product/hoodie-v1"
        />

        <ProductCard
          image={tee}
          alt="Tee NEO.NAUTZ"
          name="TEE V1"
          price="€60"
          href="/product/tee-v1"
        />

        <ProductCard
          image={cap}
          alt="Cap NEO.NAUTZ"
          name="CAP V1"
          price="€40"
          href="/product/cap-v1"
        />
      </div>
    </div>
  </section>
</Layout>
